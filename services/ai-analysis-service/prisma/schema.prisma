generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalysisResult {
  id         String   @id @default(uuid())
  surveyId   String
  responseId String
  sentiment  String
  summary    String
  createdAt  DateTime @default(now())
}
